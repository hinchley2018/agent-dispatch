# Copy to .env and fill in real values. .env is gitignored.

ANTHROPIC_API_KEY=

# Discord incoming webhook URL (channel settings → Integrations → Webhooks).
# Leave blank to disable notifications.
DISCORD_WEBHOOK_URL=

MYSQL_HOST=
MYSQL_PORT=
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=

# ── cron_dispatch.py ──────────────────────────────────────────────────────
# owner/repo whose issues should be auto-dispatched
DISPATCH_REPO=owner/repo
# local checkout path on the machine running the cron job
DISPATCH_REPO_PATH=/path/to/local/checkout
# label added to an issue once it's been dispatched successfully
DISPATCH_LABEL=agent-dispatched
# label added when the agent errors out or hits its turn/budget cap without
# finishing; also excluded from future runs so it's flagged, not retried forever
DISPATCH_FAIL_LABEL=agent-incomplete
# max number of new issues to dispatch per run
DISPATCH_MAX_ISSUES=3
# open|closed|all
DISPATCH_STATE=open
# tech stack context prepended to the prompt so the agent follows the
# project's conventions (optional, e.g. "Next.js")
DISPATCH_STACK=Next.js
# extra instructions appended to every issue's prompt (optional)
DISPATCH_INSTRUCTIONS=
# max agent turns per issue before it's cut off
DISPATCH_MAX_TURNS=60
# max USD spend per issue before the agent stops early (cost circuit breaker)
DISPATCH_MAX_BUDGET_USD=5.0
# label added when an issue is judged too large for one PR (skipped, not dispatched)
DISPATCH_SPLIT_LABEL=needs-splitting
# set to "false" to skip the pre-dispatch scope-check call
DISPATCH_SCOPE_CHECK=true
# branch repo_path is force-reset to (discarding uncommitted changes/untracked
# files) before and after every issue, so failures don't contaminate the next one
DISPATCH_BASE_BRANCH=main
